{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": "apps/customer-web",
  "cleanUrls": false,
  "rewrites": [
    { "source": "/account", "destination": "/account.html" },
    { "source": "/register", "destination": "/account.html" },
    { "source": "/login", "destination": "/account.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/join", "destination": "/unavailable.html" },
    { "source": "/join/:path*", "destination": "/unavailable.html" },
    { "source": "/site.js", "destination": "/app.js" },
    { "source": "/site.css", "destination": "/styles.css" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'none'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self'; font-src 'self'; object-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/account",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/register",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/login",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ]
}
