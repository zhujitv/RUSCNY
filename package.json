{
  "name": "zh-ru-live-translator",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.8",
  "workspaces": [
    "services/api"
  ],
  "engines": {
    "node": "22.23.x",
    "npm": "10.9.x"
  },
  "scripts": {
    "dev": "npm run dev --workspace services/api",
    "build": "npm run build --workspace services/api",
    "typecheck": "npm run typecheck --workspace services/api",
    "test": "npm run test --workspace services/api",
    "test:integration": "npm run test:integration --workspace services/api",
    "test:coverage": "npm run test:coverage --workspace services/api",
    "test:web": "node --test apps/customer-web/site.test.mjs deploy/deep-links/site/join/app.security.test.mjs",
    "db:generate": "npm run prisma:generate --workspace services/api",
    "db:migrate": "npm run prisma:migrate --workspace services/api"
  }
}
